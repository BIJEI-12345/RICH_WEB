# Copy to ".env" in the project root. Never commit .env (see .gitignore).

# MySQL — php/config.php reads DB_HOST_AWS, etc.
DB_HOST_AWS=
DB_PORT_AWS=3306
DB_USER_AWS=
DB_PASS_AWS=
DB_NAME_AWS=

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=RICH Bigte

APP_TIMEZONE=Asia/Manila
APP_NAME=Barangay Bigte

# Optional: GROQ_API_KEY= (concerns + fallback para sa Emergency AI kung walang dedicated key sa ibaba)
# Emergency Reports — AI buod (analytics graph + emergency page). Kung blanko, ginagamit ang GROQ_API_KEY sa itaas.
EMERGENCY_GRAPH_GROQ_API_KEY=
# Optional: GOOGLE_VISION_API_KEY=

# Para sa document request analysis (analytics / AI — ilagay ang key mula sa provider)
DOCUMENT_REQUEST_ANALYSIS_API_KEY=

# Para sa sentiment analysis ng concerns.statement (positive/negative words + interpretation)
SENTIMENT_ANALYSIS_API_KEY=

# Census (Analytics → Census) — opsyonal na hiwalay na Groq key bawat Demographic tile / by-sitio table
# Senior 60+ tile & section → GROQ_API_KEY_CENSUS_SENIOR_CITIZENS
# Widowed → GROQ_API_KEY_CENSUS_WIDOWED | Employed → GROQ_API_KEY_CENSUS_EMPLOYED | Unemployed → GROQ_API_KEY_CENSUS_UNEMPLOYED
# Students → GROQ_API_KEY_CENSUS_STUDENTS | PWD → GROQ_API_KEY_CENSUS_PWD | Indigenous (IP) → GROQ_API_KEY_CENSUS_INDIGENOUS
# Sa PHP: parehong pangalan ng constants sa config.php (GROQ_API_KEY_CENSUS_*).
GROQ_API_KEY_CENSUS_SENIOR_CITIZENS=
GROQ_API_KEY_CENSUS_WIDOWED=
GROQ_API_KEY_CENSUS_EMPLOYED=
GROQ_API_KEY_CENSUS_UNEMPLOYED=
GROQ_API_KEY_CENSUS_STUDENTS=
GROQ_API_KEY_CENSUS_PWD=
GROQ_API_KEY_CENSUS_INDIGENOUS=
