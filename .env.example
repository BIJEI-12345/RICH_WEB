# Database Configuration
# AWS RDS Database
DB_HOST_AWS=your-aws-rds-host.amazonaws.com
DB_PORT_AWS=3306
DB_USER_AWS=your-aws-username
DB_PASS_AWS=your-aws-password
DB_NAME_AWS=your-database-name

# Local Database (for development)
DB_HOST_LOCAL=localhost
DB_PORT_LOCAL=3306
DB_USER_LOCAL=root
DB_PASS_LOCAL=
DB_NAME_LOCAL=rich_db

# Email/SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=RICH Bigte
# 0=off, 2=verbose SMTP log to PHP / Apache error log (use when OTP email fails)
SMTP_DEBUG=0
# true=verify TLS cert. On XAMPP/Windows if OTP never sends, use: SMTP_SSL_VERIFY=false
SMTP_SSL_VERIFY=true

# API Keys
GROQ_API_KEY=your-groq-api-key-here

# Application Settings
APP_TIMEZONE=Asia/Manila
APP_NAME=Barangay Bigte
